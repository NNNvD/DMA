# DMA example environment configuration

# Embeddings provider: "openai", "local", or "disabled"
EMBEDDING_PROVIDER=disabled

# OpenAI (required if EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_COST_PER_1M_TOKENS=

# Local sentence-transformers (required if EMBEDDING_PROVIDER=local)
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Database URL (async SQLAlchemy)
# This repo's checked-in local profile is the Abomination Vaults playtest setup.
# Use a different filename when starting a separate campaign.
DATABASE_URL=sqlite+aiosqlite:///./dma-abomination-vaults.db

# Local private campaign bundle.
# Collaborators should receive this ignored folder directly and place it here.
DMA_PRIVATE_DATA_ROOT=./assets/imports/misc/private-local
DMA_CAMPAIGN_ID=abomination-vaults

# Legacy Obsidian compatibility path. The live DM Panel now reads generated
# campaign material from DMA_PRIVATE_DATA_ROOT first.
OBSIDIAN_VAULT_PATH=./obsidian-abomination-vaults-vault
REFERENCE_PDF_ROOT=./assets/imports/misc/private-local/reference/raw
DUNGEON_MAP_ROOT=./assets/imports/misc/private-local/media
DUNGEON_ROOM_KEY_ROOT=./assets/imports/misc/private-local/room-keys

# Text-to-speech
# TTS_PROVIDER=browser uses Chrome/OS browser voices only.
# TTS_PROVIDER=piper uses a local Piper binary and voice model for higher-quality English narration.
TTS_PROVIDER=browser
PIPER_BINARY_PATH=piper
PIPER_VOICE_PATH=
PIPER_SPEAKER_ID=
PIPER_LENGTH_SCALE=
PIPER_NOISE_SCALE=
PIPER_NOISE_W=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/dma.log

# Metrics
METRICS_LATENCY_SAMPLES=500

# MapTool integration
# Experimental placeholder for a future HTTP bridge or sidecar.
# This is not the same thing as MapTool's normal tcp:// game server port.
# For the local bridge prototype in this repo, use http://127.0.0.1:5005
MAPTOOL_BASE_URL=http://127.0.0.1:5005
MAPTOOL_USERNAME=
MAPTOOL_PASSWORD=
MAPTOOL_TIMEOUT_SECONDS=10
MAPTOOL_MAX_RETRIES=3
