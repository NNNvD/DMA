# DMA example environment configuration

# Embeddings provider: "openai", "local", or "disabled"
EMBEDDING_PROVIDER=disabled

# OpenAI (required if EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_COST_PER_1M_TOKENS=

# Local sentence-transformers (required if EMBEDDING_PROVIDER=local)
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Database URL (async SQLAlchemy)
DATABASE_URL=sqlite+aiosqlite:///./dma.db

# Local campaign workspaces
OBSIDIAN_VAULT_PATH=./obsidian-abomination-vaults-vault
REFERENCE_PDF_ROOT=./assets/imports/misc/private-local/reference/raw
DUNGEON_MAP_ROOT=./assets/imports/misc/private-local/media
DUNGEON_ROOM_KEY_ROOT=./assets/imports/misc/private-local/room-keys

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/dma.log

# Metrics
METRICS_LATENCY_SAMPLES=500

# MapTool integration
# Experimental placeholder for a future HTTP bridge or sidecar.
# This is not the same thing as MapTool's normal tcp:// game server port.
# For the local bridge prototype in this repo, use http://127.0.0.1:5005
MAPTOOL_BASE_URL=http://127.0.0.1:5005
MAPTOOL_USERNAME=
MAPTOOL_PASSWORD=
MAPTOOL_TIMEOUT_SECONDS=10
MAPTOOL_MAX_RETRIES=3
